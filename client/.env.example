# Firebase (Web app config from Firebase Console → Project settings)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Web Push (FCM): Firebase Console → Project settings → Cloud Messaging → Web Push certificates → Key pair
EXPO_PUBLIC_FIREBASE_VAPID_KEY=

# Cloud Functions region (must match deployed functions, e.g. deleteMyAccount)
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# Google Sign-In — Web client ID (Expo / OAuth); use iOS/Android clients for native builds as needed
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
